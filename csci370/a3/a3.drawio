          <mxGeometry height="30" width="350" x="170" y="190" as="geometry" />
        </mxCell>
        <mxCell id="XT0C5xJ1Y6wHnVOJZxkw-26" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;autosize=1;resizable=0;" value="Result(s, c, e) ::= Realtors(_, s, c, e)" vertex="1">
          <mxGeometry height="30" width="220" x="175" y="130" as="geometry" />
        </mxCell>
        <mxCell id="XT0C5xJ1Y6wHnVOJZxkw-28" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;span class=&quot;hljs-keyword&quot;&gt;SELECT&lt;/span&gt;&amp;nbsp;(email, otherInfo)&amp;nbsp;&lt;span class=&quot;hljs-keyword&quot;&gt;FROM&lt;/span&gt; Clients&amp;nbsp;&lt;span class=&quot;hljs-keyword&quot;&gt;WHERE&amp;nbsp;&lt;/span&gt;name &lt;span class=&quot;hljs-keyword&quot;&gt;IS&lt;/span&gt; &lt;span class=&quot;hljs-keyword&quot;&gt;NULL&lt;/span&gt;;" vertex="1">
          <mxGeometry height="30" width="420" x="140" y="410" as="geometry" />
        </mxCell>
        <mxCell id="XT0C5xJ1Y6wHnVOJZxkw-30" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;SELECT (Property.civicAddress, Realtor.serviceName)&lt;/div&gt;&lt;div&gt;FROM ClosedListings ClosedListing&lt;/div&gt;&lt;div&gt;JOIN Listings Listing ON ClosedListing.listingID = Listing.listingID&lt;/div&gt;&lt;div&gt;JOIN Properties Property ON Listing.folio = Property.folio&lt;/div&gt;&lt;div&gt;JOIN Realtors Realtor ON Listing.listedBy = Realtor.RID&lt;/div&gt;&lt;div&gt;WHERE ClosedListing.purchasePrice &amp;gt; (Listing.askingPrice + 10000);&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="670" x="10" y="650" as="geometry" />
        </mxCell>
        <mxCell id="XT0C5xJ1Y6wHnVOJZxkw-32" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="SELECT (Property.civicAddress, Listing.listDate, Realtor.serviceName, Listing.askingPrice) from Listings Listing JOIN Properties Property on Listing.folio = Property.folio JOIN Realtors Realtor ON Listing.listedBy = Realtor.RID WHERE Listing.status = &#39;Active&#39;;" vertex="1">
          <mxGeometry height="30" width="630" x="90" y="940" as="geometry" />
        </mxCell>
        <mxCell id="XT0C5xJ1Y6wHnVOJZxkw-33" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Result(a, d, s, p) ::= Listings(_, folio, RID, d, &#39;Active&#39;, _, p), Properties(folio, a, _, _, _), Realtors(RID, s, _, _, _)&amp;nbsp;" vertex="1">
          <mxGeometry height="30" width="590" x="110" y="870" as="geometry" />
        </mxCell>
        <mxCell id="XT0C5xJ1Y6wHnVOJZxkw-36" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Result(a, y) ::= Properties(folio, a, _, y, _), MajorProjects(folio, y2, _), a like &#39;%Icarus%&#39;, y2 &amp;gt; y" vertex="1">
          <mxGeometry height="30" width="520" x="100" y="1320" as="geometry" />
        </mxCell>
        <mxCell id="XT0C5xJ1Y6wHnVOJZxkw-37" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="SELECT DISTINCT (Property.civicAdress, Property.builtYear) FROM Properties Property JOIN MajorProjects Major ON Property.foli = Major.folio WHERE Property.civicAddress LIKE &#39;%Icarus%&#39; AND Major.year &amp;gt; Property.builtYear;" vertex="1">
          <mxGeometry height="30" width="630" x="100" y="1390" as="geometry" />
        </mxCell>
        <mxCell id="XT0C5xJ1Y6wHnVOJZxkw-38" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Result(a, s) ::= ClosedListings(LID, _, _, purchasePrice), Listings(LID, folio, RID, _, _, _, askingPrice), Properties(folio, a, _, _, _), Realtors(RID, s, _, _, _), purchasePrice &amp;gt; askingPrice + 10000" vertex="1">
          <mxGeometry height="30" width="660" x="140" y="590" as="geometry" />
        </mxCell>
